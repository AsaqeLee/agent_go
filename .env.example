# Copy to .env and fill in values (do not commit .env).
# Loaded automatically by cmd/agent on startup (does not override existing exports).

# Required for OpenAI / most cloud providers
OPENAI_API_KEY=sk-...

# Optional — defaults shown
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama example:
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen2.5:7b

# Turn logs: 1/true (default) or 0/false
AGENT_VERBOSE=1
